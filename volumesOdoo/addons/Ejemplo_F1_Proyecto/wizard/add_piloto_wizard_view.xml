<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_f1_add_piloto_wizard_form" model="ir.ui.view">
        <field name="name">f1.add.piloto.wizard.form</field>
        <field name="model">f1.add.piloto.wizard</field>
        <field name="arch" type="xml">
            <form string="Añadir Piloto">
                <group>
                    <field name="name"/>
                    <field name="apellido"/>
                    <field name="escuderia_id"/>
                </group>
                <footer>
                    <button name="action_create_piloto" type="object" string="Guardar Piloto" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_f1_add_piloto_wizard" model="ir.actions.act_window">
        <field name="name">Añadir Piloto Rápido</field>
        <field name="res_model">f1.add.piloto.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_f1_add_piloto_wizard" name="Wizard: Añadir Piloto" parent="menu_f1_root" action="action_f1_add_piloto_wizard" sequence="50"/>
</odoo>