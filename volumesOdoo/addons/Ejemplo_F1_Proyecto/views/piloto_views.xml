<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_f1_piloto_graph" model="ir.ui.view">
        <field name="name">f1.piloto.graph</field>
        <field name="model">f1.piloto</field>
        <field name="arch" type="xml">
            <graph string="Puntos del Mundial" type="bar">
                <field name="name" type="row"/>
                <field name="puntos_totales" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_f1_piloto_tree" model="ir.ui.view">
        <field name="name">f1.piloto.tree</field>
        <field name="model">f1.piloto</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="apellido"/>
                <field name="escuderia_id"/>
                <field name="puntos_totales"/>
            </tree>
        </field>
    </record>

    <record id="action_f1_piloto" model="ir.actions.act_window">
        <field name="name">Pilotos</field>
        <field name="res_model">f1.piloto</field>
        <field name="view_mode">tree,form,graph</field>
    </record>

    <menuitem id="menu_f1_piloto" name="Pilotos" parent="menu_f1_root" action="action_f1_piloto" sequence="20"/>
</odoo>