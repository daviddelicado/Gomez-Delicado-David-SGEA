<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_f1_piloto_search" model="ir.ui.view">
        <field name="name">f1.piloto.search</field>
        <field name="model">f1.piloto</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="escuderia_id"/>
                <filter string="Activos" name="activos" domain="[('estado', '=', 'activo')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Escudería" name="group_escuderia" context="{'group_by':'escuderia_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_f1_piloto_tree" model="ir.ui.view">
        <field name="name">f1.piloto.tree</field>
        <field name="model">f1.piloto</field>
        <field name="arch" type="xml">
            <tree decoration-danger="estado == 'lesionado'" decoration-info="estado == 'activo'" decoration-muted="estado == 'retirado'">
                <field name="name"/>
                <field name="apellido"/>
                <field name="escuderia_id"/>
                <field name="estado"/>
                <field name="puntos_totales" sum="Total Puntos"/>
            </tree>
        </field>
    </record>

    <record id="view_f1_piloto_form" model="ir.ui.view">
        <field name="name">f1.piloto.form</field>
        <field name="model">f1.piloto</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="estado" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre..."/>
                            <field name="apellido" placeholder="Apellido..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="apellido"/>
                        <field name="nacionalidad"/>
                        <field name="escuderia_id"/>
                        <field name="puntos_totales"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_f1_piloto_graph" model="ir.ui.view">
        <field name="name">f1.piloto.graph</field>
        <field name="model">f1.piloto</field>
        <field name="arch" type="xml">
            <graph string="Puntos del Mundial" type="bar">
                <field name="name" type="row"/>
                <field name="puntos_totales" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_f1_piloto" model="ir.actions.act_window">
        <field name="name">Pilotos</field>
        <field name="res_model">f1.piloto</field>
        <field name="view_mode">tree,form,graph</field>
    </record>
</odoo>