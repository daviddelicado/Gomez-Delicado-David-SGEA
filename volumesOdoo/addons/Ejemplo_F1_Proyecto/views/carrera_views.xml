<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_f1_carrera_calendar" model="ir.ui.view">
        <field name="name">f1.carrera.calendar</field>
        <field name="model">f1.carrera</field>
        <field name="arch" type="xml">
            <calendar string="Calendario F1" date_start="date_start" date_stop="date_stop" color="circuito">
                <field name="name"/>
                <field name="circuito"/>
            </calendar>
        </field>
    </record>

    <record id="view_f1_carrera_tree" model="ir.ui.view">
        <field name="name">f1.carrera.tree</field>
        <field name="model">f1.carrera</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="circuito"/>
                <field name="date_start"/>
            </tree>
        </field>
    </record>

    <record id="action_f1_carrera" model="ir.actions.act_window">
        <field name="name">Grandes Premios</field>
        <field name="res_model">f1.carrera</field>
        <field name="view_mode">tree,calendar,form</field>
    </record>

    <menuitem id="menu_f1_carrera" name="Carreras" parent="menu_f1_root" action="action_f1_carrera" sequence="30"/>
</odoo>