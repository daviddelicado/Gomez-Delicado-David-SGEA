<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_f1_escuderia_tree" model="ir.ui.view">
        <field name="name">f1.escuderia.tree</field>
        <field name="model">f1.escuderia</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="nacionalidad"/>
                <field name="jefe_equipo"/>
            </tree>
        </field>
    </record>

    <record id="view_f1_escuderia_form" model="ir.ui.view">
        <field name="name">f1.escuderia.form</field>
        <field name="model">f1.escuderia</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="logo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la Escudería..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="nacionalidad"/>
                        <field name="jefe_equipo"/>
                        <field name="presupuesto"/>
                    </group>
                    <notebook>
                        <page string="Pilotos">
                            <field name="piloto_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_f1_escuderia" model="ir.actions.act_window">
        <field name="name">Escuderías</field>
        <field name="res_model">f1.escuderia</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>