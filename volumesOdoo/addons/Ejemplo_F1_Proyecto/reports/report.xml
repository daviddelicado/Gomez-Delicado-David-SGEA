<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_piloto" model="ir.actions.report">
        <field name="name">Ficha de Piloto</field>
        <field name="model">f1.piloto</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">Ejemplo_F1_Proyecto.report_piloto_template</field>
        <field name="report_file">Ejemplo_F1_Proyecto.report_piloto_template</field>
        <field name="binding_model_id" ref="model_f1_piloto"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_piloto_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Ficha del Piloto: <span t-field="o.name"/> <span t-field="o.apellido"/></h2>
                        <p><strong>Nacionalidad:</strong> <span t-field="o.nacionalidad"/></p>
                        <p><strong>Escudería:</strong> <span t-field="o.escuderia_id.name"/></p>
                        <p><strong>Estado Actual:</strong> <span t-field="o.estado"/></p>
                        <h3>Puntos Totales de la Temporada: <span t-field="o.puntos_totales"/></h3>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>